{
  "extends": ["./base.json"],
  "plugins": [
    "eslint",
    "typescript",
    "import",
    "oxc",
    "unicorn",
    "react",
    "jsx-a11y",
    "react-perf",
    "nextjs"
  ],
  "ignorePatterns": [".next/**", "out/**", "build/**", "next-env.d.ts"],
  "env": {
    "browser": true
  },
  "settings": {
    "react": {
      "version": "detect"
    },
    "next": {
      "rootDir": "."
    }
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}
