{
  "extends": ["./base.json"],
  "plugins": [
    "eslint",
    "typescript",
    "import",
    "oxc",
    "unicorn",
    "react",
    "jsx-a11y",
    "react-perf"
  ],
  "env": {
    "browser": true
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}
