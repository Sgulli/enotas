{
  "name": "@repo/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "generate:schema": "pnpm --filter=@repo/db run build && cd ../.. && pnpm dlx auth@latest generate --config=packages/auth/src/auth.ts --output=packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.3",
    "@paralleldrive/cuid2": "^3.3.0",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "better-auth": "^1.6.3",
    "valibot": "^1.3.1",
    "@better-auth/core": "^1.6.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/oxlint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2"
  }
}
